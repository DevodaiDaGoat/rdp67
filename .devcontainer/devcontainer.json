{
  "name": "Debian KDE (noVNC)",
  "image": "mcr.microsoft.com/devcontainers/base:debian",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/git-lfs:1": {}
  },

  "forwardPorts": [6080],

  "portsAttributes": {
    "6080": {
      "label": "KDE Desktop (noVNC)",
      "onAutoForward": "openBrowser"
    }
  },

  "postCreateCommand": "apt update && apt install -y kde-standard konsole xvfb x11vnc novnc websockify dbus-x11 autocutsel",

  "postStartCommand": ".devcontainer/start.sh",

  "remoteUser": "vscode"
}